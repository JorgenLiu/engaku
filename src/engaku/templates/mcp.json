{
  "inputs": [
    {
      "type": "promptString",
      "id": "db-dsn",
      "description": "Database connection string for dbhub (e.g. postgresql://user:pass@host:5432/db).",
      "password": true
    }
  ],
  "servers": {
    "chrome-devtools": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest", "--headless"]
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp"
    },
    "dbhub": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@bytebase/dbhub@latest", "--transport", "stdio", "--config", "${workspaceFolder}/.vscode/dbhub.toml"],
      "env": {
        "DBHUB_DSN": "${input:db-dsn}"
      }
    }
  }
}
